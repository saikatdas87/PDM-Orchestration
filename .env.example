# Local development — values read directly from environment variables
PDM_BASE_URL=http://localhost:8081
PDM_API_KEY=your-pdm-api-key

UPLOAD_BASE_URL=http://localhost:8082
UPLOAD_API_KEY=your-upload-api-key

# AWS deployment — activate the aws profile to read from Secrets Manager instead
# SPRING_PROFILES_ACTIVE=aws
# AWS_REGION=eu-west-1
#
# Expected secrets in AWS Secrets Manager:
#   /pdm-orchestration/pdm-base-url
#   /pdm-orchestration/pdm-api-key
#   /pdm-orchestration/upload-base-url
#   /pdm-orchestration/upload-api-key
